{
	"name": "yamadori",
	"private": true,
	"version": "0.0.7",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "node scripts/generate-icons.mjs && vite build",
		"build:android": "npm run build && node scripts/sync-android-version.mjs && npx cap sync android",
		"android:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/run-android.ps1",
		"release:play-internal": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/prepare-play-internal-test.ps1",
		"cap:sync": "npx cap sync android",
		"cap:open": "npx cap open android",
		"icons": "node scripts/generate-icons.mjs",
		"privacy:docs": "node scripts/generate-privacy-docs.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"i18n:check": "node scripts/validate-i18n.mjs",
		"i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy localStorage preferredLanguage baseLocale",
		"check": "svelte-kit sync && npm run i18n:check && npm run i18n:compile && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@capacitor/android": "^8.4.1",
		"@capacitor/cli": "^8.4.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^26.0.0",
		"sharp": "^0.35.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@capacitor-community/background-geolocation": "^1.2.26",
		"@capacitor-community/keep-awake": "^7.1.0",
		"@capacitor-community/screen-brightness": "^8.0.0",
		"@capacitor-community/volume-buttons": "^8.0.0",
		"@capacitor/app": "^8.1.0",
		"@capacitor/camera": "^8.2.0",
		"@capacitor/core": "^8.4.1",
		"@capacitor/filesystem": "^8.1.2",
		"@capacitor/geolocation": "^8.2.0",
		"@capacitor/haptics": "^8.0.2",
		"@capacitor/keyboard": "^8.0.5",
		"@capacitor/local-notifications": "^8.2.0",
		"@capacitor/preferences": "^8.0.1",
		"@capacitor/share": "^8.0.1",
		"@capacitor/status-bar": "^8.0.2",
		"@capgo/native-purchases": "^8.4.6",
		"@inlang/paraglide-js": "^2.20.1",
		"capacitor-community-device-orientation": "^7.2.0",
		"capacitor-secure-storage-plugin": "^0.13.0",
		"capacitor-voice-recorder": "^7.0.6",
		"fflate": "^0.8.3",
		"geomagnetism": "^0.2.0",
		"idb-keyval": "^6.2.5",
		"maplibre-gl": "^5.6.0"
	}
}
