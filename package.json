{
	"name": "yamadori",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "node scripts/generate-icons.mjs && vite build",
		"build:pages": "cross-env BASE_PATH=/Yamadori node scripts/generate-icons.mjs && cross-env BASE_PATH=/Yamadori vite build && node scripts/copy-spa-fallback.mjs",
		"icons": "node scripts/generate-icons.mjs",
		"preview:pages": "cross-env BASE_PATH=/Yamadori vite preview",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^26.0.0",
		"cross-env": "^10.1.0",
		"sharp": "^0.35.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-pwa": "^1.3.0"
	},
	"dependencies": {
		"idb-keyval": "^6.2.5",
		"maplibre-gl": "^5.6.0",
		"pocketbase": "^0.27.0"
	}
}
